# macOS
.DS_Store
*.DS_Store

# Xcode — generated by XcodeGen, never commit
*.xcodeproj/
*.xcworkspace/
!*.xcworkspace/contents.xcworkspacedata

# Xcode build artifacts
build/
DerivedData/
*.ipa
*.dSYM.zip
*.dSYM

# Swift Package Manager
.build/
.swiftpm/

# Android
apps/android/.gradle/
apps/android/build/
apps/android/**/*.apk
apps/android/**/*.aab
apps/android/local.properties

# Rust
core/rust/target/

# Env / secrets
.env
*.env.local

# Local AI tools (OpenCode / Cline / Codex)
.opencode
.opencode/opencode.db
.opencode/opencode.db-shm
.opencode/opencode.db-wal
.clineignore
.codex/

# Claude agent worktrees (ephemeral, never commit)
.claude/worktrees/
